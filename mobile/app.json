{
  "expo": {
    "name": "D\u00edvida Zero",
    "slug": "DividaZero",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/brand/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dividazero.mobile",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E97800",
        "foregroundImage": "./assets/brand/android-adaptive-foreground.png",
        "backgroundImage": "./assets/brand/android-adaptive-background.png",
        "monochromeImage": "./assets/brand/android-adaptive-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/brand/notification-icon-monochrome.png",
          "color": "#F48C25"
        }
      ],
      "expo-sharing"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
